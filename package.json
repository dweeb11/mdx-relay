{
  "name": "mdx-relay",
  "version": "0.1.0",
  "description": "Review and publish Obsidian notes as repository-ready MDX.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,ts,mjs}\"",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --project unit --project jsdom",
    "test:coverage": "vitest run --project unit --project jsdom --coverage",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:bundle": "npm run build && node esbuild.config.mjs probe-node-builtins && node scripts/inspect-bundle.mjs && node scripts/run-bundle-worker-smoke.mjs",
    "test:private-baseline": "vitest run --project private-baseline --passWithNoTests",
    "build": "node esbuild.config.mjs production",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run test:integration && npm run test:bundle"
  },
  "dependencies": {
    "@jsquash/jpeg": "1.6.0",
    "@jsquash/png": "3.1.1",
    "@jsquash/webp": "1.5.0",
    "@mdx-js/mdx": "3.1.1",
    "acorn": "8.17.0",
    "micromark": "4.0.2",
    "micromark-util-decode-string": "2.0.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.15.3",
    "@vitest/coverage-v8": "3.2.7",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "obsidian": "1.13.1",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.65.0",
    "vitest": "3.2.7"
  }
}
